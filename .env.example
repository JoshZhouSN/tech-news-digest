# Optional runtime configuration for tech-news-digest
# Copy values into your shell environment or a local, untracked .env file.

# Twitter/X backend: auto | getxapi | twitterapiio | bird | official
TWITTER_API_BACKEND=auto
GETX_API_KEY=
TWITTERAPI_IO_KEY=
X_BEARER_TOKEN=
BIRD_CLI=bird
AUTH_TOKEN=
CT0=

# Web search backend: auto | brave | tavily
WEB_SEARCH_BACKEND=auto
BRAVE_API_KEY=
BRAVE_API_KEYS=
BRAVE_PLAN=free
TAVILY_API_KEY=

# GitHub API
GITHUB_TOKEN=

# Optional GitHub App auth for token generation
GH_APP_ID=
GH_APP_INSTALL_ID=
GH_APP_KEY_FILE=
